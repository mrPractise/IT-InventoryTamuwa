# ── Required ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.railway.app

# ── Database ──────────────────────────────────────────────────────────────────
# Railway: DATABASE_URL is auto-injected when you add the Postgres plugin.
# Docker:  uncomment DB_HOST=db and leave DATABASE_URL blank.
# Local:   leave both blank to use SQLite.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_HOST=db
DB_NAME=inventory_db
DB_USER=postgres
DB_PASSWORD=change_me_postgres_password
DB_PORT=5432

# ── Optional: auto-create superuser on first start ────────────────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change_me_admin_password

# ── Proxy / HTTPS ─────────────────────────────────────────────────────────────
USE_X_FORWARDED_HOST=True
