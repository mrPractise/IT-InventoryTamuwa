# ── Required ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# DB_HOST must be set for PostgreSQL to be used.
# In Docker, this is 'db' (the service name in docker-compose.yml).
# Leave blank to fall back to SQLite for local dev (no Docker).
DB_NAME=inventory_db
DB_USER=postgres
DB_PASSWORD=change_me_postgres_password
DB_HOST=db
DB_PORT=5432

# ── Optional: auto-create superuser on first container start ──────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change_me_admin_password
