# ── Required ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.up.railway.app

# ── Database ──────────────────────────────────────────────────────────────────
# Railway: DATABASE_URL is auto-injected when you add the Postgres plugin.
# Local:   leave blank to use SQLite.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Optional: auto-create superuser on first deploy ───────────────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change_me_admin_password

# ── Proxy headers ─────────────────────────────────────────────────────────────
USE_X_FORWARDED_HOST=True
